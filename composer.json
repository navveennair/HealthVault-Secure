{
    "name": "medichain/healthvault-secure",
    "description": "Post-incident secure refactor of the E-MedicVault search, auth, and crypto_vault modules.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "HealthVault\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HealthVault\\Tests\\": "tests/"
        }
    }
}
