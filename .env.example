# =============================================================================
# HealthVault-Secure environment template
# Copy this file to ".env" and fill in real values. ".env" itself is
# git-ignored so secrets never enter version control history.
# =============================================================================

# --- Database (PDO) ---------------------------------------------------------
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=medic_vault_db
DB_USER=medic_vault_app
DB_PASS=change-me
DB_CHARSET=utf8mb4

# --- Cryptography ------------------------------------------------------------
# 32-byte (256-bit) AES key, base64-encoded. Generate with:
#   php -r "echo base64_encode(random_bytes(32));"
CRYPTO_VAULT_KEY_B64=REPLACE_WITH_BASE64_32_BYTE_KEY

# --- Authentication ------------------------------------------------------------
# Argon2id tuning (defaults are sane for a shared app server; raise on
# dedicated hardware). Values map to password_hash() PASSWORD_ARGON2ID options.
ARGON2ID_MEMORY_COST=65536
ARGON2ID_TIME_COST=4
ARGON2ID_THREADS=2
